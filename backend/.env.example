# MongoDB Atlas Connection
ATLAS_DB_URL=mongodb+srv://username:password@cluster.mongodb.net/StayScape?retryWrites=true&w=majority

# Session Secret (generate a random string for production)
SECRET=your-secret-key-here-change-this-in-production

# Cloudinary Configuration (for image uploads)
CLOUD_NAME=your-cloudinary-cloud-name
CLOUD_API_KEY=your-cloudinary-api-key
CLOUD_API_SECRET=your-cloudinary-api-secret

# Server Port (optional - defaults to 8080)
PORT=8080
